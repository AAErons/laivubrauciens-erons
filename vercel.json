{
  "functions": {
    "api/[[...path]].js": {
      "includeFiles": "server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/auth/:path*", "destination": "/api/auth/:path*" },
    { "source": "/users/:path*", "destination": "/api/users/:path*" },
    { "source": "/photos/:path*", "destination": "/api/photos/:path*" },
    { "source": "/game-progress", "destination": "/api/game-progress" },
    { "source": "/game-progress/:path*", "destination": "/api/game-progress/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
